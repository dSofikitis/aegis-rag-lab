# --- Provider selection ---
# openai | ollama | stub
AEGIS_LLM_PROVIDER=openai
# openai | ollama | deterministic
AEGIS_EMBEDDINGS_PROVIDER=openai

# --- OpenAI ---
AEGIS_OPENAI_API_KEY=
AEGIS_OPENAI_MODEL=gpt-4o-mini
AEGIS_EMBEDDING_MODEL=text-embedding-3-small
AEGIS_EMBEDDING_DIM=1536

# --- Ollama (local LLM, e.g. Gemma 4) ---
# Inside docker compose use http://ollama:11434; on host use http://localhost:11434
AEGIS_OLLAMA_BASE_URL=http://ollama:11434
# Default is qwen2.5:3b (~2 GB) for solid grounding incl. negation.
# Smaller/faster: gemma3:1b (~815 MB), qwen2.5:1.5b (~1 GB).
# Premium: phi3.5:3.8b (~2.2 GB), gemma4:e2b (~7.2 GB, multimodal).
AEGIS_OLLAMA_MODEL=qwen2.5:3b
AEGIS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
AEGIS_OLLAMA_REQUEST_TIMEOUT_S=180
# nomic-embed-text outputs 768-dim vectors. If you switch to ollama embeddings
# from OpenAI's 1536-dim model you must wipe the postgres volume:
# docker compose down -v

# --- Storage ---
AEGIS_VECTOR_BACKEND=postgres
AEGIS_DATABASE_URL=postgresql+psycopg://aegis:aegis@postgres:5432/aegis
AEGIS_REDIS_URL=redis://redis:6379/0

# --- Service ---
AEGIS_LOG_LEVEL=INFO
AEGIS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AEGIS_CHUNK_SIZE=800
AEGIS_CHUNK_OVERLAP=120
AEGIS_RETRIEVAL_K=5
# Drop chunks below this similarity floor (0.0..1.0). 0.0 = no filter.
# Applies to vector cosine when reranker is off, or to the cross-encoder
# sigmoid score when the reranker is on. With decomposition each
# sub-query lands directly on its target so 0.2 is a safe default;
# raise to 0.4-0.5 if you want stricter filtering, lower for recall.
AEGIS_RETRIEVAL_MIN_SIMILARITY=0.2

# --- Reranker (cross-encoder) ---
# Rescores top candidates with cross-encoder/ms-marco-MiniLM-L-6-v2 to
# fix bi-encoder weaknesses (e.g. negation blindness on short text).
# Adds ~50-300 ms per query depending on candidate count.
AEGIS_RERANK_ENABLED=true
AEGIS_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
AEGIS_RERANK_CANDIDATES=20

# --- Query decomposition (MultiQuery) ---
# Rewrites compound / list-style queries into atomic sub-questions and
# unions the retrieved chunks, fixing multi-hop and aggregation cases
# that cross-encoders struggle with. Adds one LLM call per query
# (~300-500 ms warm). Skipped for inputs shorter than the min length.
AEGIS_DECOMPOSE_ENABLED=true
AEGIS_DECOMPOSE_MAX_SUBQUERIES=4
AEGIS_DECOMPOSE_MIN_QUESTION_LENGTH=20

AEGIS_MAX_CONTEXT_CHARS=4000
AEGIS_GUARDRAILS_ENABLED=true
AEGIS_REQUEST_TIMEOUT_S=20
